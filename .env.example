# Copy this file to ".env" and fill in your own values.

# Your Neon Postgres connection string (from the Neon dashboard → Connect)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Password to log into the admin CMS
ADMIN_PASSWORD="choose-a-password"

# A long random string used to sign the login cookie
SESSION_SECRET="a-long-random-secret-string"

# Your site's public URL (used for SEO). Set to your Vercel URL after deploy.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
